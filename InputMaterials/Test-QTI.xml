  <itemBody>
    <div>
      <p>筋肉を3つに分けると、骨格筋と心筋と何ですか。</p>
      <p><small>Guideline: デフォルト (InputMaterials)</small></p>
    </div>
    <choiceInteraction responseIdentifier="RESPONSE" shuffle="true">
      <prompt>Select the correct answer:</prompt>
      <simpleChoice identifier="choice_1">平滑筋</simpleChoice>
      <simpleChoice identifier="choice_2">横紋筋</simpleChoice>
      <simpleChoice identifier="choice_3">肋間筋</simpleChoice>
      <simpleChoice identifier="choice_4">腱筋</simpleChoice>
    </choiceInteraction>
  </itemBody>
  <responseProcessing>
    <responseCondition>
      <responseIf>
        <match>
          <variable identifier="RESPONSE"/>
          <baseValue baseType="identifier">平滑筋</baseValue>
        </match>
        <setOutcomeValue identifier="SCORE">
          <baseValue baseType="float">1</baseValue>
        </setOutcomeValue>
      </responseIf>
    </responseCondition>
  </responseProcessing>
